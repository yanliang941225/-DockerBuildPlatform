# Qiniu Configuration
QINIU_ACCESS_KEY=your_access_key_here
QINIU_SECRET_KEY=your_secret_key_here
QINIU_BUCKET=docker-build-files
QINIU_REGION=z0

# Server Configuration
HOST=0.0.0.0
PORT=8000
FILE_EXPIRE_HOURS=5
MAX_FILE_SIZE_MB=500
MAX_CONTEXT_SIZE_MB=500

# Security
RATE_LIMIT_PER_MINUTE=30
ALLOWED_DOCKERFILE_EXTENSIONS=.dockerfile,.Dockerfile,Dockerfile,Dockerfile.dev

# Build Configuration
BUILD_TIMEOUT_MINUTES=60
BUILD_WORKERS=4
