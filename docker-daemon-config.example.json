# ============================================
# Docker 国内镜像加速配置
# ============================================

# 方法 1: 通过 Docker Desktop 配置
# 打开 Docker Desktop -> Settings -> Docker Engine
# 在右侧编辑器中添加以下配置:

{
  "registry-mirrors": [
    "https://docker.npmmirror.com",
    "https://mirror.ccs.tencentyun.com",
    "https://dockerhub.azk8s.cn",
    "https://reg-mirror.qiniu.com"
  ]
}

# 方法 2: macOS/Linux 修改 daemon.json
# sudo mkdir -p /etc/docker
# sudo tee /etc/docker/daemon.json <<EOF
# {
#   "registry-mirrors": [
#     "https://docker.npmmirror.com",
#     "https://mirror.ccs.tencentyun.com",
#     "https://dockerhub.azk8s.cn",
#     "https://reg-mirror.qiniu.com"
#   ]
# }
# EOF
# sudo systemctl restart docker

# 方法 3: Windows Docker Desktop
# 右键托盘图标 -> Settings -> Docker Engine
# 添加上述 JSON 配置

# ============================================
# 国内常用镜像源
